## Client (Vite) env vars
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

## Server (Vercel Functions under /api)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=

## Optional
STRIPE_WEBHOOK_SECRET=

## App URL (used in email links and Stripe Connect redirects)
## Set to your production URL in deployment; defaults to http://localhost:3000
APP_URL=http://localhost:3000

## Email (Resend) — https://resend.com
## Get a free API key at https://resend.com/api-keys
## Verify your domain at https://resend.com/domains before sending to external emails.
## For testing, set RESEND_FROM_EMAIL=onboarding@resend.dev and emails go to your own address.
RESEND_API_KEY=
RESEND_FROM_EMAIL=ZipsMarket <orders@yourdomain.com>

